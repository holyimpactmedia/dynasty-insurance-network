# Supabase - required for auth and all database operations
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL - used for redirects and absolute URLs (e.g. https://yourdomain.com)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Resend - used for transactional email (lead confirmation, agent alerts)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Twilio - used for SMS notifications to agents on new leads
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Anthropic - used for AI lead scoring
ANTHROPIC_API_KEY=sk-ant-your-key

# TrustedForm - used to claim certificates on lead submission
TRUSTEDFORM_API_KEY=your-trustedform-api-key
