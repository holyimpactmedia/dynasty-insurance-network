# Supabase - required for auth and all database operations
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL - used for redirects and absolute URLs (e.g. https://yourdomain.com)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Resend - used for transactional email (lead confirmation + admin notifications)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Admin email - receives a rich notification on every new lead (all data + AI score + USHA status)
ADMIN_EMAIL=you@yourdomain.com

# USHA Marketplace / LeadArena - where leads are posted for agents to purchase
# Contact support@leadarena.com to obtain credentials and API spec
USHA_API_URL=https://app.ushamarketplace.com/api/v1/leads
USHA_API_KEY=your-usha-api-key

# Twilio - optional, kept for future use (SMS no longer sent to internal agents)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Anthropic - used for AI lead scoring (0-100 score + urgency + recommended approach)
ANTHROPIC_API_KEY=sk-ant-your-key

# TrustedForm - used to claim TCPA compliance certificates on lead submission
TRUSTEDFORM_API_KEY=your-trustedform-api-key
